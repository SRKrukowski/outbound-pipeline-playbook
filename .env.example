# Outbound Pipeline Playbook — environment variables
# Copy this file to .env and fill in your keys. The skill will read from .env at runtime.

# Anthropic API key (Claude does the drafting)
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Exa API key (research signals)
# Get one at https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Apollo.io API key (contact enrichment)
# Get one at https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# Composio token (recommended — handles Gmail + Apollo OAuth)
# Get one at https://app.composio.dev/api-keys
# If you skip Composio, set GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET below for raw Gmail API
COMPOSIO_API_KEY=

# Raw Gmail OAuth (only needed if NOT using Composio)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Sender identity (used in draft attribution)
SENDER_NAME=
SENDER_EMAIL=
SENDER_TITLE=
SENDER_COMPANY=

# Pipeline behavior
# Set to "true" to skip Apollo enrichment + Gmail draft staging (free dry-run mode)
DRY_RUN=false
